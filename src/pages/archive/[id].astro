---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('archive');
  return posts.map(post => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<Base title={post.data.title} description={post.data.description}>
  <article>
    <div class="post-header">
      <h1>{post.data.title}</h1>
      <div class="date">{post.data.date.toISOString().slice(0, 10)}</div>
      {post.data.tags.length > 0 && (
        <div class="tags">{post.data.tags.join(' / ')}</div>
      )}
    </div>
    <div class="prose">
      <Content />
    </div>
  </article>
</Base>

<style>
  .tags { font-size: 0.75rem; color: var(--text-dim); margin-top: 0.25rem; }
</style>
